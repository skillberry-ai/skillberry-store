# ----------- MANDATORY IDENTIFIERS ------------------
# Names: No spaces, letter start, letters, digits, hyphen, underscore
# Python path names: also no hyphen
# Make sure NO TRAILING WHITE SPACES after values! No quotes or double-quotes!
ASSET_NAME := your asset name here, e.g., example-service
ACRONYM := acronym of the asset name, e.g., ES
DESC_NAME := descriptive name of the asset, e.g., Example Service
VERSION_LOCATION := relative path to location of git version module e.g., src/example_service/version.py
# Set to 1 if this asset is using LLM services - watsonx or RITS
USE_LLM_SVCS := 0/1
# Set these two below even if your asset is not a service - it allows execution control 
SERVICE_ENTRY_MODULE := your service entry module name, e.g., example_service.main
SERVICE_NAME := $(ASSET_NAME)
# If this asset is an actual network service, define these service settings as well
SERVICE_PORTS := space-separated port numbers (first is always main port), e.g., 8000 8002
SERVICE_PORT_ROLES := space-separated one-word role labels matching the above port list, e.g., MAIN UI
SERVICE_HOST := IP to listen on for the service, e.g., 0.0.0.0
# If your service can generate SDK (OpenAPI), set the flag below to 1
SERVICE_HAS_SDK := 1
# If this service container uses persistent mounts, please specify here as pairs of mount:path - separated by space, e.g. /data:/mydata /logs:/tmp/logs
CNTR_MOUNTS := 
# ----------------------------------------------------

# CUSTOM Makefile stuff here

# Uncomment additional Makefiles of your project from the respective categories - if you have them 
#include .mk/dev.mk
#include .mk/process.mk
#include .mk/docker.mk
#include .mk/ci.mk
